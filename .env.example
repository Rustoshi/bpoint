# ─────────────────────────────────────────────
#  BPoint — Environment Variables Template
#  Copy this file to .env.local and fill values.
#  This file IS safe to commit (no real secrets).
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NEXT_PUBLIC_APP_NAME=BPoint
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── MongoDB ──────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/bpoint?retryWrites=true&w=majority
MONGODB_DB_NAME=bpoint

# ── Auth / JWT ───────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d

# ── OTP ──────────────────────────────────────
OTP_EXPIRES_MINUTES=10
OTP_LENGTH=6

# ── Mailtrap (Email — Development) ───────────
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=
MAILTRAP_FROM_NAME=BPoint
MAILTRAP_FROM_EMAIL=no-reply@bpoint.ng

# ── Email (Production) ───────────────────────
# RESEND_API_KEY=
# SENDGRID_API_KEY=

# ── Bcrypt ───────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Session / Cookie ─────────────────────────
COOKIE_SECRET=
COOKIE_SECURE=false
COOKIE_MAX_AGE_DAYS=7

# ── Next.js Public Config ────────────────────
NEXT_PUBLIC_SUPPORT_EMAIL=support@bpoint.ng
NEXT_PUBLIC_WHATSAPP_NUMBER=2348000000000

# ── Cloudinary (browser-direct unsigned uploads) ─────────
# Files upload directly browser → Cloudinary; nothing flows through Vercel.
# Create an unsigned upload preset at https://cloudinary.com/console.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ── Admin Seed (scripts/seed-admin.ts) ───────
ADMIN_EMAIL=admin@bpoint.ng
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
